{
  "name": "sigaa-me",
  "private": true,
  "version": "1.1.0-beta",
  "description": "Desktop app for UFC's SIGAA",
  "author": "Bruno Lage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Laginho/SIGAA-ME.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "release": "tsc && vite build && electron-builder --win --publish always",
    "release:patch": "standard-version --release-as patch && git push --follow-tags origin HEAD",
    "release:minor": "standard-version --release-as minor && git push --follow-tags origin HEAD",
    "preview": "npm run build && start .\\release\\%npm_package_version%\\win-unpacked\\SIGAA-ME.exe",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:e2e": "tsc && vite build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/mime-types": "^3.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.0.2",
    "standard-version": "^9.5.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.4"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "axios": "^1.13.2",
    "cheerio": "^1.0.0",
    "electron-updater": "^6.8.3",
    "mime-types": "^3.0.2",
    "playwright": "^1.56.1",
    "sqlite": "^5.1.1"
  }
}